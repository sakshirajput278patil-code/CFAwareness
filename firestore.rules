rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /history/{deviceId}/entries/{entryId} {
      // Allow create only. No read/update/delete from client to prevent PII leakage.
      allow create: if request.resource.data.keys().hasOnly(['total_kg_co2e', 'breakdown', 'timestamp'])
                    && request.resource.data.total_kg_co2e is number;
      allow read, update, delete: if false;
    }
  }
}
